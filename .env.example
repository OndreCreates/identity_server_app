DB_NAME=identity_server
DB_USER=identity_app
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme

# Must match OAUTH_CLIENT_SECRET in demo-client/.env.local
DEMO_CLIENT_SECRET=demo-client-dev-secret-change-me

# Base64-encoded 256-bit AES key used to encrypt TOTP secrets at rest.
# Generate a real one per environment, e.g.: openssl rand -base64 32
MFA_ENCRYPTION_KEY=clbLPsWb+rlRiazzQY/Sf50oVPAxu7Co3/JimoQEkQY=

# Only needed for a real deployment (behind actual domains, not localhost). Both must be
# changed together -- APP_ISSUER is baked into every token's `iss` claim and must match
# wherever the identity server is actually reachable; DEMO_CLIENT_REDIRECT_URI is validated
# against the registered client's redirect_uri on every /oauth2/authorize call.
# APP_ISSUER=https://identity.example.com
# DEMO_CLIENT_REDIRECT_URI=https://demo.example.com/callback
