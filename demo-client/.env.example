# Identity server this demo client talks to -- must be reachable from the BROWSER (it's the
# redirect target for /oauth2/authorize and the value baked into every token's `iss` claim).
IDENTITY_SERVER_ISSUER=http://localhost:9000

# Optional. Only needed when this server can't reach the identity server at the same address
# the browser uses -- e.g. in Docker Compose, where the browser needs "http://localhost:9000"
# but this container needs the service name "http://identity-server:9000". Defaults to
# IDENTITY_SERVER_ISSUER when unset, which is correct for plain local (non-Docker) dev.
# IDENTITY_SERVER_INTERNAL_URL=http://identity-server:9000

# Must exactly match the registered client in oauth2_registered_client
OAUTH_CLIENT_ID=demo-client

# Must match DEMO_CLIENT_SECRET in the identity-server's .env -- server-side only, never
# exposed to the browser (this app is a confidential client, not a public SPA client).
OAUTH_CLIENT_SECRET=demo-client-dev-secret-change-me

# Must exactly match the redirect_uri registered for demo-client (incl. trailing slash / path)
OAUTH_REDIRECT_URI=http://localhost:3000/callback
